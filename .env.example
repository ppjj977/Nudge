# --- Database (Turso / libSQL) ---
# Local dev: a file URL works with @libsql/client, e.g. file:./relay.db
# Turso dev/prod: libsql://<db>-<org>.turso.io
TURSO_DATABASE_URL=file:./relay.db
TURSO_AUTH_TOKEN=

# --- Groq (extraction + image-to-text) ---
GROQ_API_KEY=
# Set from Groq's current catalogue at build time. Do NOT hardcode in source.
# Text extraction model (capable, instruction-following "versatile" tier).
GROQ_MODEL=
# Optional: vision-capable Groq model for image-to-text. If empty, falls back
# to local Tesseract OCR. Both paths must output into captures.normalized_text.
GROQ_VISION_MODEL=

# --- Extraction tuning ---
# Items below this land in the review tray instead of the live timeline.
CONFIDENCE_THRESHOLD=0.6

# --- Privacy / retention ---
# Purge captures.raw_content after this many days (keeps derived tasks).
RAW_RETENTION_DAYS=30

# --- Outbound email (phase 1 needs this for magic-link auth; phase 2 for
#     reminders + digest). Pick a transactional sender (Resend, Postmark, ...).
RESEND_API_KEY=
MAIL_FROM=relay@example.com

# --- Inbound email (phase 3). Cloudflare Email Routing / Mailgun / Postmark. ---
INBOUND_WEBHOOK_SECRET=

# --- Phase 1 dev convenience ---
# Until magic-link auth lands, the app operates as this single seeded user.
DEFAULT_USER_EMAIL=adam@example.com
DEFAULT_USER_TIMEZONE=Europe/London
