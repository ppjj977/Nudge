# --- Database (Turso / libSQL) ---
# Local dev: a file URL works with @libsql/client, e.g. file:./relay.db
# Turso dev/prod: libsql://<db>-<org>.turso.io
TURSO_DATABASE_URL=file:./relay.db
TURSO_AUTH_TOKEN=

# --- Groq (extraction + image-to-text) ---
GROQ_API_KEY=
# Set from Groq's current catalogue at build time. Do NOT hardcode in source.
# Text extraction model (capable, instruction-following "versatile" tier).
GROQ_MODEL=
# Optional: vision-capable Groq model for image-to-text. If empty, falls back
# to local Tesseract OCR. Both paths must output into captures.normalized_text.
GROQ_VISION_MODEL=
# Speech-to-text model for voice notes (Groq Whisper). Default: whisper-large-v3
GROQ_WHISPER_MODEL=

# --- Extraction tuning ---
# Items below this land in the review tray instead of the live timeline.
CONFIDENCE_THRESHOLD=0.6

# --- Privacy / retention ---
# Purge captures.raw_content after this many days (keeps derived tasks).
RAW_RETENTION_DAYS=30

# --- Outbound email (Resend). Sends reminders, the daily digest, and (later)
#     magic-link auth. https://resend.com
RESEND_API_KEY=
MAIL_FROM=nudge@example.com

# --- Web push (app notifications). Generate a VAPID keypair once with:
#       npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A contact URL or mailto: for the push service (required by the spec).
VAPID_SUBJECT=mailto:nudge@example.com

# --- Scheduling (cron) ---
# Shared secret protecting the cron endpoints; the GitHub Actions workflow
# (.github/workflows/cron.yml) sends it. Use a long random string.
CRON_SECRET=

# Public base URL of the deployed app, used for links in emails/notifications,
# auth redirects, and by the cron workflow. e.g. https://nudge-s1mn.onrender.com
APP_BASE_URL=

# --- Auth ---
# Google sign-in (optional; email + magic-link work without it). Create an
# OAuth client at https://console.cloud.google.com → Credentials, with redirect
# URI <APP_BASE_URL>/api/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email-in (receiving) ---
# Subdomain that per-user inbound addresses live on, e.g. in.nudgelive.co.uk.
# Set up receiving for this subdomain in Resend, then point its webhook at
# <APP_BASE_URL>/api/inbound. Leave blank to hide the email-in address.
INBOUND_DOMAIN=
# Signing secret ("whsec_…") from the Resend webhook; verifies inbound posts.
INBOUND_WEBHOOK_SECRET=

# --- Native push (FCM, for the Capacitor Android app) ---
# Firebase → Project settings → Service accounts → Generate new private key.
# Paste the full JSON here (raw, or base64-encoded). Enables app-branded push.
FCM_SERVICE_ACCOUNT=

# --- Inbound email (phase 3). Cloudflare Email Routing / Mailgun / Postmark. ---
INBOUND_WEBHOOK_SECRET=

# --- Phase 1 dev convenience ---
# Until magic-link auth lands, the app operates as this single seeded user.
DEFAULT_USER_EMAIL=adam@example.com
DEFAULT_USER_TIMEZONE=Europe/London
